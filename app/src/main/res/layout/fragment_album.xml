<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶栏：普通模式 — 返回 + 标题 -->
    <LinearLayout
        android:id="@+id/layout_normal_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:background="@color/surface"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/actionModeCloseDrawable"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="相册"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_background" />
    </LinearLayout>

    <!-- 顶栏：选择模式 — 取消 + 已选数量 + 分享 + 删除 -->
    <LinearLayout
        android:id="@+id/layout_selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:background="@color/primary_container"
        android:elevation="2dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_cancel_select"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/actionModeCloseDrawable"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="取消选择" />

        <TextView
            android:id="@+id/tv_select_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="已选 0 张"
            android:textSize="16sp"
            android:textColor="@color/on_primary_container" />

        <Button
            android:id="@+id/btn_select_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="全选"
            android:textSize="12sp"
            android:textColor="@color/primary" />

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="分享" />

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除"
            android:tint="@color/error_red" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_photos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="2dp"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="还没有照片\n回首页点「拍照」试试"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/interim_text"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
