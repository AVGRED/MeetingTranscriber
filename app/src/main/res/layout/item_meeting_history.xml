<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- 状态指示灯 -->
        <View
            android:id="@+id/iv_status"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_status" />

        <!-- 会议信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="会议_2026-05-22_10:30" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/on_surface"
                android:layout_marginTop="2dp"
                tools:text="2026-05-22 10:30" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/interim_text"
                android:layout_marginTop="2dp"
                tools:text="45分30秒" />

            <!-- 内容状态行：录音 · 纪要 · 转写条数 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 录音指示器 -->
                <LinearLayout
                    android:id="@+id/layout_has_recording"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:id="@+id/indicator_recording_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/circle_indicator_recording" />

                    <TextView
                        android:id="@+id/indicator_recording_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="录音"
                        android:textSize="12sp"
                        android:textColor="@color/indicator_recording" />
                </LinearLayout>

                <!-- 分隔点 -->
                <TextView
                    android:id="@+id/tv_dot_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="12sp"
                    android:textColor="@color/interim_text"
                    android:visibility="gone" />

                <!-- 纪要指示器 -->
                <LinearLayout
                    android:id="@+id/layout_has_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:id="@+id/indicator_summary_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/circle_indicator_summary" />

                    <TextView
                        android:id="@+id/indicator_summary_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="纪要"
                        android:textSize="12sp"
                        android:textColor="@color/indicator_summary" />
                </LinearLayout>

                <!-- 分隔点 -->
                <TextView
                    android:id="@+id/tv_dot_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="12sp"
                    android:textColor="@color/interim_text"
                    android:visibility="gone" />

                <!-- 转写记录数（始终显示） -->
                <TextView
                    android:id="@+id/tv_speakers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/interim_text"
                    tools:text="3 位说话人 · 128 条记录" />

                <!-- 标签 -->
                <TextView
                    android:id="@+id/tv_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/primary"
                    android:background="@drawable/search_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="1dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"
                    tools:text="产品"
                    tools:visibility="visible" />
            </LinearLayout>

        </LinearLayout>

        <!-- 导出按钮 -->
        <ImageButton
            android:id="@+id/btn_export"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="导出" />

        <!-- 上传按钮（仅离线会议显示） -->
        <ImageButton
            android:id="@+id/btn_upload"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_upload"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="上传转写"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- 恢复按钮（回收站中显示） -->
        <ImageButton
            android:id="@+id/btn_restore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="恢复"
            android:visibility="gone" />

        <!-- 删除按钮 -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
