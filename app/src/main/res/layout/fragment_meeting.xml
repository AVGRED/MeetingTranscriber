<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 连接状态指示灯 -->
        <View
            android:id="@+id/iv_status"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_status" />

        <!-- 计时器 -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:fontFamily="monospace"
            tools:text="00:23:15" />

        <!-- 离线录音按钮（未开会时显示） -->
        <Button
            android:id="@+id/btn_offline"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="离线"
            android:textColor="#FF9800"
            android:visibility="visible" />

        <!-- 演示按钮（未开会时显示） -->
        <Button
            android:id="@+id/btn_demo"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="演示"
            android:textColor="@color/accent"
            android:visibility="visible" />

        <!-- 暂停按钮（会议中显示） -->
        <Button
            android:id="@+id/btn_pause"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂停"
            android:visibility="gone"
            android:textColor="@color/primary"
            tools:visibility="visible" />

        <!-- 开始/结束按钮 -->
        <Button
            android:id="@+id/btn_start_end"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始会议"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

    <!-- 会议标题输入（未开会时显示） -->
    <LinearLayout
        android:id="@+id/layout_title_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="会议标题"
            android:textSize="14sp"
            android:textColor="@color/on_surface"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/et_meeting_title"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/search_bg"
            android:paddingHorizontal="10dp"
            android:singleLine="true"
            android:textSize="14sp"
            android:hint="输入会议标题..."
            android:maxLength="50" />

        <Spinner
            android:id="@+id/spinner_language"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:spinnerMode="dropdown"
            android:dropDownVerticalOffset="48dp" />

        <Spinner
            android:id="@+id/spinner_tag"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:spinnerMode="dropdown"
            android:dropDownVerticalOffset="48dp" />
    </LinearLayout>

    <!-- 当前引擎标签 -->
    <TextView
        android:id="@+id/tv_engine_label"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:text="当前引擎：FunASR 云端"
        android:textSize="11sp"
        android:textColor="@color/on_surface_variant"
        android:gravity="center"
        android:background="@color/surface_variant"
        app:layout_constraintTop_toBottomOf="@id/layout_title_input" />

    <!-- 演示模式提示条 -->
    <TextView
        android:id="@+id/tv_demo_badge"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:text="● 演示模式 — 模拟 3 人会议对话"
        android:textSize="11sp"
        android:textColor="@color/on_primary"
        android:gravity="center"
        android:background="#FF9800"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_engine_label"
        tools:visibility="visible" />

    <!-- 连接状态提示条（重连/失败时显示） -->
    <LinearLayout
        android:id="@+id/layout_connection_banner"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="#FF9800"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_demo_badge"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="重新连接中..."
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_retry"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="重试"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- 错误信息条 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:background="#D32F2F"
        android:visibility="gone"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        app:layout_constraintTop_toBottomOf="@id/layout_connection_banner"
        tools:text="鉴权失败，请检查 AccessKey 配置。" />

    <!-- 摘要生成进度 -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_error"
        tools:visibility="visible" />

    <!-- 转写列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transcript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/progress_summary"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_transcript_segment" />

</androidx.constraintlayout.widget.ConstraintLayout>
