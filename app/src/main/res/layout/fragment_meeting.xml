<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 连接状态指示灯 -->
        <View
            android:id="@+id/iv_status"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_status" />

        <!-- 计时器 -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:fontFamily="monospace"
            tools:text="00:23:15" />

        <!-- 演示按钮（未开会时显示） -->
        <Button
            android:id="@+id/btn_demo"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="演示"
            android:textColor="@color/accent"
            android:visibility="visible" />

        <!-- 暂停按钮（会议中显示） -->
        <Button
            android:id="@+id/btn_pause"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂停"
            android:visibility="gone"
            android:textColor="@color/primary"
            tools:visibility="visible" />

        <!-- 开始/结束按钮 -->
        <Button
            android:id="@+id/btn_start_end"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始会议"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

    <!-- 演示模式提示条 -->
    <TextView
        android:id="@+id/tv_demo_badge"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:text="● 演示模式 — 模拟 3 人会议对话"
        android:textSize="11sp"
        android:textColor="@color/on_primary"
        android:gravity="center"
        android:background="#FF9800"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:visibility="visible" />

    <!-- 转写列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transcript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tv_demo_badge"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_transcript_segment" />

</androidx.constraintlayout.widget.ConstraintLayout>
