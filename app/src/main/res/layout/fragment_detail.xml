<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 返回按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingTop="4dp"
        android:background="@color/surface">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/actionModeCloseDrawable"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />
    </LinearLayout>

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:background="@color/surface"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            tools:text="会议_2026-05-22_10:30" />

        <TextView
            android:id="@+id/tv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/on_surface"
            android:layout_marginTop="4dp"
            tools:text="2026-05-22 10:30 · 45分30秒" />

        <TextView
            android:id="@+id/tv_speakers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/interim_text"
            android:layout_marginTop="2dp"
            tools:text="3 位说话人 · 128 条记录" />

        <!-- 纪要区（有内容时才显示） -->
        <LinearLayout
            android:id="@+id/layout_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/summary_bg"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="会议纪要"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:gravity="top|start"
                android:textSize="14sp"
                android:textColor="@color/on_background"
                android:lineSpacingExtra="4dp"
                android:inputType="textMultiLine|textAutoCorrect"
                android:background="@null"
                tools:text="会议讨论了Q2产品规划方向，确定了三个重点项目的优先级..." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btn_regenerate_summary"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重新生成"
                    android:textSize="12sp"
                    android:textColor="@color/accent" />

                <Button
                    android:id="@+id/btn_save_summary"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="保存"
                    android:textSize="12sp"
                    android:textColor="@color/primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- 搜索 + 导出 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="搜索转写内容..."
                android:paddingHorizontal="12dp"
                android:background="@drawable/search_bg"
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <Button
                android:id="@+id/btn_format"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="规整"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_export"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="导出"
                android:textColor="@color/primary" />

        </LinearLayout>
    </LinearLayout>

    <!-- 转写列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transcript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_transcript_segment" />

</LinearLayout>
